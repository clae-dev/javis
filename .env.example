# OpenAI
OPENAI_API_KEY=
LLM_MODEL=gpt-4o
FAST_MODEL=gpt-4o-mini
EMBEDDING_MODEL=text-embedding-3-small
STT_MODEL=gpt-4o-mini-transcribe
TTS_MODEL=gpt-4o-mini-tts
TTS_VOICE=alloy

# 웹 검색 (없으면 ddgs 무료 폴백 사용)
TAVILY_API_KEY=

# Database (Docker compose 사용 시 자동 주입됨. 로컬 실행 시에만 수정)
DATABASE_URL=postgresql+asyncpg://jarvis:jarvis@localhost:5432/jarvis
DB_PASSWORD=jarvis

# 비서 인격 / 로캘
ASSISTANT_NAME=자비스
OWNER_NAME=창래
TIMEZONE=Asia/Seoul

# 동작 토글
USE_POSTGRES_CHECKPOINTER=true
ENABLE_SCHEDULER=true

# Google (선택)
GOOGLE_CREDENTIALS_PATH=credentials/google.json
GOOGLE_TOKEN_PATH=credentials/token.json

# 음성 데몬 웨이크워드 (openWakeWord, 무료·키 불필요). "헤이 자비스 / hey jarvis"로 깸.
# 끄려면 JAVIS_OWW=0 (그러면 Vosk 방식). 임계값 0~1, 높을수록 엄격(오인식↓, 기본 0.5).
JAVIS_OWW=1
JAVIS_OWW_THRESHOLD=0.5
